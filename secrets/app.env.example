# secrets/app.env.example
# ───────────────────────────────────────────────────────────────
# このファイルを app.env にコピーし, 使う項目だけ値を埋める.
# 全項目「任意」: 何も設定しなくても baseline は動く
#   （SQLite + スタブ分析 + ログ通知 + 認証無効）.
# app.env は .gitignore 済み. 実値は絶対に commit しない.
# Gmail の認証情報は gmail.env 側に置く（このファイルには書かない）.
# ───────────────────────────────────────────────────────────────

# === DB: Supabase / Postgres に上げる場合のみ ===
# 既定は未設定＝ローカル SQLite (data/SaikoLook.db).
# Supabase の接続文字列例（psycopg2 ドライバ指定）:
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/postgres

# === 認証(JWT): 有効化する場合のみ ===
# AUTH_ENABLED=true
# JWT_SECRET=  # openssl rand -hex 32 で生成した十分長いランダム値
# AUTH_USERNAME=admin
# AUTH_PASSWORD=  # デモ用ログインパスワード

# === LLM 分析: 実モデルを使う場合のみ（既定はオフラインのスタブ）===
# 分析は 1 メールにつき生涯 1 回だけ呼ぶ（保存済み結果を再利用し従量課金を抑制）.
# ANALYZER=gemini               # gemini | anthropic | openai | ollama | stub
# GEMINI_API_KEY=               # https://aistudio.google.com/apikey で取得（無料枠あり）
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# LLM_MODEL=                    # 空ならプロバイダ別の既定（gemini→gemini-2.5-flash-lite 最安）

# -- Ollama（別PCの OpenAI 互換サーバ・従量課金/レート制限なし・本文はLAN外に出ない）--
# ANALYZER=ollama
# OLLAMA_BASE_URL=http://100.x.y.z:11434   # ★Tailscale の IP を推奨（MagicDNS名は不可・下記注意）
# LLM_MODEL=qwen2.5             # 別PCで `ollama pull` 済みのモデル名に合わせる
# 別PC側: OLLAMA_HOST=0.0.0.0:11434 で起動（Tailscale 経由で待受） + `ollama pull qwen2.5`
# 注意: API を Docker で動かす場合, コンテナは *.ts.net（MagicDNS）を解決できないため
#       OLLAMA_BASE_URL には 100.x.y.z の数値 IP を使うこと.

# === 通知: メール/Slack を使う場合のみ（既定はログ出力）===
# NOTIFIER=email               # log | email | slack
# NOTIFY_IMPORTANCE_THRESHOLD=4
# -- Email(SMTP) --
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=               # SMTP 用アプリパスワード
# NOTIFY_EMAIL_FROM=you@gmail.com
# NOTIFY_EMAIL_TO=you@gmail.com
# -- Slack(Incoming Webhook) --
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# === 取得スケジューラ（任意の調整）===
# SCHEDULER_ENABLED=true
# INGEST_INTERVAL_SECONDS=300
# INGEST_LIMIT=10
