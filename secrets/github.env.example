# GitHub OAuth App の認証情報（読み取り専用 / notifications scope）
#
# 発行手順:
#   GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
#   Authorization callback URL に http://127.0.0.1:8000/auth/github/callback を設定
#   （本番は AWS 等のドメインに合わせる）
#
# このファイルはサンプル（コミット可）. 実値は secrets/github.env に記入すること
# （secrets/*.env は .gitignore 済みのためコミットされない）.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
